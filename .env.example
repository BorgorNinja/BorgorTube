# BorgorTube – Environment configuration
# Copy to .env and adjust, then: docker compose up -d

# ── Backend ───────────────────────────────────────────────────────────────
# Port the FastAPI server listens on (inside container: always 8000)
BORGORTUBE_PORT=8000

# SQLite database file path (inside container, mounted from borgortube_data volume)
BORGORTUBE_DB=/data/borgortube.db

# Directory where completed downloads are stored
BORGORTUBE_DOWNLOADS=/data/downloads

# ── Deno MPV bridge ───────────────────────────────────────────────────────
# WebSocket port for the Deno MPV IPC bridge
BORGORTUBE_DENO_PORT=8001

# Path to mpv's UNIX IPC socket (must match --input-ipc-server in mpv launch)
MPV_SOCKET=/tmp/mpvsocket

# How often (ms) the bridge reconnects / polls mpv
POLL_MS=1000

# ── Rate limiting ─────────────────────────────────────────────────────────
# slowapi limits (per IP per minute) – adjust in main.py if needed
# Default: search=20/min, video=30/min, general=200/min

# ── Development ───────────────────────────────────────────────────────────
# Set to "development" to enable FastAPI auto-reload
APP_ENV=production
